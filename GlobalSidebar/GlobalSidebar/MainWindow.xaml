<Window
    x:Class="GlobalSidebar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:GlobalSidebar.ViewModels"
    Title="GlobalSidebar"
    Width="340"
    Height="{Binding Source={x:Static SystemParameters.PrimaryScreenHeight}}"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStartupLocation="Manual">

    <!--
        窗口设计说明：
        - WindowStyle="None" + AllowsTransparency="True"：无边框透明窗口
        - ShowInTaskbar="False"：不在任务栏显示
        - 宽度 = 折叠条宽度(12) + 展开面板宽度(320) + 边距 = 340
        - 高度 = 屏幕高度，占满整个屏幕左侧
        - 整体使用 Canvas 布局，通过 TranslateTransform.X 控制滑动动画
          仅修改 RenderTransform 而非 Layout 属性，避免触发 Measure/Arrange 重算
    -->

    <Window.Resources>
        <!-- ViewModel 实例 -->
        <vm:MainViewModel x:Key="ViewModel" />

        <!--
            折叠态 → 展开态：滑出动画
            使用 DoubleAnimation 修改 TranslateTransform.X
            From=0（折叠位置）To=-320（展开位置，面板完全可见）
            Duration=250ms，CubicEase EaseOut 实现减速缓出效果
            原理：CubicEase(t) = 1 - (1-t)^3，在动画末段减速，手感自然
        -->
        <Storyboard x:Key="ExpandStoryboard" Completed="OnExpandCompleted">
            <DoubleAnimation
                Storyboard.TargetName="SidebarTransform"
                Storyboard.TargetProperty="X"
                From="0"
                To="-320"
                Duration="0:0:0.250">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!--
            展开态 → 折叠态：收回动画
            From=-320（展开位置）To=0（折叠位置）
            同样使用 CubicEase EaseOut，250ms
        -->
        <Storyboard x:Key="CollapseStoryboard" Completed="OnCollapseCompleted">
            <DoubleAnimation
                Storyboard.TargetName="SidebarTransform"
                Storyboard.TargetProperty="X"
                From="-320"
                To="0"
                Duration="0:0:0.250">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- 小横条 Hover 宽度过渡动画：12px → 16px -->
        <Storyboard x:Key="HoverInStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="CollapsedBar"
                Storyboard.TargetProperty="Width"
                From="12"
                To="16"
                Duration="0:0:0.150">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- 小横条 Hover 离开宽度过渡动画：16px → 12px -->
        <Storyboard x:Key="HoverOutStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="CollapsedBar"
                Storyboard.TargetProperty="Width"
                From="16"
                To="12"
                Duration="0:0:0.150">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- 呼吸灯发光效果样式 -->
        <Style x:Key="GlowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#404080FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#8060A0FF" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect
                                Color="#6090FF"
                                BlurRadius="8"
                                ShadowDepth="0"
                                Opacity="0.6" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <StaticResource ResourceKey="ViewModel" />
    </Window.DataContext>

    <!--
        主容器：整个侧边栏内容
        使用 RenderTransform 实现滑动动画，仅修改 TranslateTransform.X
        不会触发 WPF 的 Layout Update（Measure + Arrange），确保 60FPS 丝滑
    -->
    <Canvas
        x:Name="RootCanvas"
        Width="340"
        Background="Transparent">

        <Canvas.RenderTransform>
            <TranslateTransform x:Name="SidebarTransform" X="0" />
        </Canvas.RenderTransform>

        <!--
            折叠态：小横条
            默认宽度 12px，高度占满屏幕
            鼠标悬停时宽度过渡到 16px，并显示发光边框
            点击触发展开动画
        -->
        <Border
            x:Name="CollapsedBar"
            Canvas.Left="0"
            Canvas.Top="0"
            Width="12"
            Height="{Binding Source={x:Static SystemParameters.PrimaryScreenHeight}}"
            Background="#1A1A2E"
            CornerRadius="0,8,8,0"
            Style="{StaticResource GlowBorderStyle}"
            MouseEnter="OnCollapsedBarMouseEnter"
            MouseLeave="OnCollapsedBarMouseLeave"
            MouseLeftButtonUp="OnCollapsedBarClick"
            Cursor="Hand">

            <!--
                呼吸灯效果：小横条内部的渐变高亮条
                使用 LinearGradientBrush 从上到下绘制一条细线
            -->
            <Border
                Width="2"
                Height="60"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                CornerRadius="1"
                Margin="0,0,2,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0060A0FF" Offset="0" />
                        <GradientStop Color="#FF60A0FF" Offset="0.5" />
                        <GradientStop Color="#0060A0FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Border>

        <!--
            展开态：功能面板
            宽度 320px，高度占满屏幕
            左侧紧贴小横条右侧（Canvas.Left=12）
            包含自定义标题栏和内容区域
        -->
        <Border
            x:Name="ExpandedPanel"
            Canvas.Left="12"
            Canvas.Top="0"
            Width="320"
            Height="{Binding Source={x:Static SystemParameters.PrimaryScreenHeight}}"
            Background="#CC1A1A2E"
            CornerRadius="0,8,8,0"
            BorderBrush="#30406080"
            BorderThickness="0,1,1,1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />  <!-- 自定义标题栏 -->
                    <RowDefinition Height="*" />    <!-- 内容区域 -->
                </Grid.RowDefinitions>

                <!--
                    自定义标题栏
                    通过 WndProc 拦截 WM_NCHITTEST 返回 HTCAPTION 实现拖拽
                -->
                <Border
                    x:Name="TitleBar"
                    Grid.Row="0"
                    Background="#0D0D1A"
                    CornerRadius="0,8,0,0"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">

                    <Grid Margin="16,0">
                        <!-- 标题 -->
                        <TextBlock
                            Text="Global Sidebar"
                            Foreground="#A0B0D0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />

                        <!-- 关闭按钮（收回面板，非退出应用） -->
                        <Button
                            x:Name="CollapseButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OnCollapseButtonClick">
                            <Path
                                Data="M6,6 L18,18 M18,6 L6,18"
                                Stroke="#8090B0"
                                StrokeThickness="1.5"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round" />
                        </Button>
                    </Grid>
                </Border>

                <!--
                    内容区域
                    此处为侧边栏功能面板的主体内容
                    可根据需求添加快捷操作、系统监控、剪贴板历史等功能
                -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12">
                        <!-- 示例：快捷操作区 -->
                        <TextBlock
                            Text="快捷操作"
                            Foreground="#7080A0"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8" />

                        <Border
                            Background="#0D0D1A"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="屏幕截图" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                                <TextBlock Text="剪贴板历史" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                                <TextBlock Text="系统监控" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                            </StackPanel>
                        </Border>

                        <!-- 示例：系统信息区 -->
                        <TextBlock
                            Text="系统信息"
                            Foreground="#7080A0"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Margin="0,8,0,8" />

                        <Border
                            Background="#0D0D1A"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="CPU: 12%" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                                <TextBlock Text="内存: 45%" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                                <TextBlock Text="磁盘: 67%" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                            </StackPanel>
                        </Border>

                        <!-- 示例：最近文件 -->
                        <TextBlock
                            Text="最近文件"
                            Foreground="#7080A0"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Margin="0,8,0,8" />

                        <Border
                            Background="#0D0D1A"
                            CornerRadius="6"
                            Padding="12">
                            <StackPanel>
                                <TextBlock Text="document.pdf" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                                <TextBlock Text="photo.png" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                                <TextBlock Text="notes.txt" Foreground="#C0D0E8" FontSize="13" Margin="0,4" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Canvas>
</Window>
