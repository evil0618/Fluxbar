<Window
    x:Class="GlobalSidebar.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GlobalSidebar 设置"
    Width="400"
    Height="350"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#1A1A2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock
            Grid.Row="0"
            Text="GlobalSidebar 设置"
            Foreground="#A0B0D0"
            FontSize="18"
            FontWeight="SemiBold"
            Margin="0,0,0,20" />

        <!-- 侧边栏宽度 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="侧边栏宽度" Foreground="#C0D0E8" FontSize="13" Margin="0,0,0,6" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <Slider
                    x:Name="SidebarWidthSlider"
                    Minimum="200"
                    Maximum="500"
                    Value="320"
                    TickFrequency="10"
                    IsSnapToTickEnabled="True" />
                <TextBlock
                    Grid.Column="1"
                    x:Name="SidebarWidthText"
                    Text="320"
                    Foreground="#A0B0D0"
                    FontSize="13"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center" />
            </Grid>
        </StackPanel>

        <!-- 小横条宽度 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="小横条宽度" Foreground="#C0D0E8" FontSize="13" Margin="0,0,0,6" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <Slider
                    x:Name="BarWidthSlider"
                    Minimum="6"
                    Maximum="24"
                    Value="12"
                    TickFrequency="2"
                    IsSnapToTickEnabled="True" />
                <TextBlock
                    Grid.Column="1"
                    x:Name="BarWidthText"
                    Text="12"
                    Foreground="#A0B0D0"
                    FontSize="13"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center" />
            </Grid>
        </StackPanel>

        <!-- 开机自启动 -->
        <CheckBox
            Grid.Row="3"
            x:Name="AutoStartCheckBox"
            Content="开机自动启动"
            Foreground="#C0D0E8"
            FontSize="13"
            Margin="0,0,0,8"
            IsChecked="False" />

        <!-- 底部按钮 -->
        <StackPanel
            Grid.Row="5"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <Button
                Content="确定"
                Width="80"
                Height="32"
                Margin="0,0,10,0"
                Click="OnOkButtonClick" />
            <Button
                Content="取消"
                Width="80"
                Height="32"
                Click="OnCancelButtonClick" />
        </StackPanel>
    </Grid>
</Window>
